// ── AuthInit ───────────────────────────────────────────────────────────────
// Validates token on app mount and restores user state from /auth/me.
function AuthInit({ children }) {
  const [ready, setReady] = useState(false)

  useEffect(() => {
    const token = authStore.getToken()
    const user  = authStore.getUser()

    if (!token) {
      authStore.clear()
      setReady(true)
      return
    }

    if (user) {
      setReady(true)
      return
    }

    // Token exists but no user cached — validate with backend
    getMe()
      .then(({ data }) => {
        authStore.setUser({
          name: data.name,
          email: data.email,
          role: data.role,
        })
      })
      .catch(() => {
        authStore.clear()
      })
      .finally(() => setReady(true))
  }, [])

  if (!ready) {
    return (
      <div className="flex items-center justify-center h-screen bg-[#F8FAFB]">
        <div className="w-8 h-8 border-4 border-[#0A4174] border-t-transparent rounded-full animate-spin" />
      </div>
    )
  }

  return children
}

// ── ProtectedRoute ─────────────────────────────────────────────────────────
function ProtectedRoute({ children, allowedRoles = [] }) {
  const location = useLocation()
  const isAuth   = authStore.isAuthenticated()
  const role     = authStore.getRole()

  if (!isAuth) {
    return <Navigate to="/login" state={{ from: location }} replace />
  }

  if (allowedRoles.length > 0 && !allowedRoles.includes(role)) {
    return <Navigate to={authStore.getHomePath()} replace />
  }

  return children
}

export default function App() {
  return (
    <BrowserRouter>
